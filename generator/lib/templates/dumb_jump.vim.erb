" NOTES:
" - All language regular expressions are ported from https://github.com/jacktasia/dumb-jump/blob/master/dumb-jump.el

let s:placeholder = 'JJJ'

let s:definitions = {
  <% definitions.each do |language, regexes| -%>
          \ '<%= language %>': [
  <% regexes.each do |regex| -%>
          \   <%= "'#{regex}'" %>,
  <% end -%>
          \ ],
  <% end -%>
          \ }

function! s:Definitions(...) abort
    let l:ft = get(a:, 1, '')
    let l:ft = empty(l:ft) ? (&filetype !=# '' ? &filetype : &buftype) : l:ft
    return get(s:definitions, l:ft, [])
endfunction

function! s:Patterns(...) abort
    let l:definitions = call('s:Definitions', a:000)
    let l:keyword = expand('<cword>')
    return map(l:definitions, 'substitute(v:val, s:placeholder, l:keyword, "g")')
endfunction

function! zero#dumb_jump#Patterns(...) abort
    return call('s:Patterns', a:000)
endfunction
